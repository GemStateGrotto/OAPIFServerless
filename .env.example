# OAPIFServerless Deployment Configuration
#
# Copy this file to .env and set your values.
# These can also be passed as CDK context: --context key=value
#
# Defaults (shown below) are defined in deploy/config.py DeploymentConfig.

# --- AWS Environment ---
# These use standard env vars (not OAPIF_-prefixed):
# AWS_REGION=us-west-2            # Also reads AWS_DEFAULT_REGION as fallback
# AWS_ACCOUNT_ID=123456789012

# --- Naming ---
# OAPIF_STACK_PREFIX=oapif
# OAPIF_ENVIRONMENT=dev          # dev | staging | prod

# --- DynamoDB ---
# OAPIF_DYNAMODB_TABLE_PREFIX=oapif
# OAPIF_DYNAMODB_BILLING_MODE=PAY_PER_REQUEST  # PAY_PER_REQUEST | PROVISIONED

# --- S3 ---
# OAPIF_S3_BUCKET_PREFIX=oapif

# --- Cognito ---
# OAPIF_COGNITO_DOMAIN_PREFIX=oapif  # Must be globally unique

# --- Lambda ---
# OAPIF_LAMBDA_MEMORY_MB=256
# OAPIF_LAMBDA_TIMEOUT_SECONDS=30
# OAPIF_LAMBDA_LOG_LEVEL=INFO    # DEBUG | INFO | WARNING | ERROR

# --- API Gateway ---
# OAPIF_API_STAGE_NAME=v1

# --- Custom Domain (optional) ---
# OAPIF_CUSTOM_DOMAIN_NAME=api.example.com
# OAPIF_CUSTOM_DOMAIN_CERTIFICATE_ARN=arn:aws:acm:us-west-2:123456789012:certificate/abc-123

# --- Google OAuth Federation (optional) ---
# OAPIF_GOOGLE_OAUTH_CLIENT_ID=887182843257-xxxx.apps.googleusercontent.com
# OAPIF_GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxx
